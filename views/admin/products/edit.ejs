<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../../partials/header') %>
    <div class="admin-container">
        <%- include('../partials/sidebar', { activePage: 'products' }) %>
        <main class="admin-main-content">
            <h1><%= title %></h1>

            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="name">Nama Produk <span class="required">*</span></label>
                    <input type="text" id="name" name="name" class="form-control" required value="<%= product.name %>">
                </div>
                <div class="form-group">
                    <label for="description">Deskripsi Produk <span class="required">*</span></label>
                    <textarea id="description" name="description" class="form-control" rows="5" required><%= product.description %></textarea>
                </div>
                <div class="form-group">
                    <label for="category">Kategori <span class="required">*</span></label>
                    <select id="category" name="category" class="form-control" required>
                        <option value="">Pilih Kategori</option>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat._id %>" <%= product.category && product.category._id.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="price">Harga Normal per Unit <span class="required">*</span></label>
                    <input type="number" id="price" name="price" class="form-control" required min="0" step="0.01" value="<%= product.price %>">
                </div>
                <div class="form-group">
                    <label for="wholesalePrice">Harga Grosir per Unit <span class="required">*</span></label>
                    <input type="number" id="wholesalePrice" name="wholesalePrice" class="form-control" required min="0" step="0.01" value="<%= product.wholesalePrice %>">
                </div>
                <div class="form-group">
                    <label for="minOrderQuantity">Min. Order Quantity (MOQ) <span class="required">*</span></label>
                    <input type="number" id="minOrderQuantity" name="minOrderQuantity" class="form-control" required min="1" value="<%= product.minOrderQuantity %>">
                </div>
                <div class="form-group">
                    <label for="stock">Stok <span class="required">*</span></label>
                    <input type="number" id="stock" name="stock" class="form-control" required min="0" value="<%= product.stock %>">
                </div>
                <div class="form-group">
                    <label for="unit">Satuan (Contoh: pcs, pak, karton) <span class="required">*</span></label>
                    <input type="text" id="unit" name="unit" class="form-control" required value="<%= product.unit %>">
                </div>
                
                <div class="form-group">
                    <label>Gambar Saat Ini:</label>
                    <div class="current-images-container">
                        <% product.images.forEach(img => { %>
                            <div class="image-preview">
                                <img src="<%= img %>" alt="Product Image" style="width: 100px; height: 100px; object-fit: cover; border-radius: 5px;">
                                <input type="hidden" name="existingImages" value="<%= img %>">
                                <button type="button" class="btn-remove-image" onclick="this.parentNode.remove()">X</button>
                            </div>
                        <% }) %>
                    </div>
                </div>
                <div class="form-group">
                    <label for="images">Tambah Gambar Baru (Maks. 5)</label>
                    <input type="file" id="images" name="images" class="form-control-file" multiple accept="image/*">
                </div>

                <div class="form-group form-check">
                    <input type="checkbox" id="isFeatured" name="isFeatured" class="form-check-input" <%= product.isFeatured ? 'checked' : '' %>>
                    <label class="form-check-label" for="isFeatured">Produk Unggulan</label>
                </div>
                <div class="form-group form-check">
                    <input type="checkbox" id="isActive" name="isActive" class="form-check-input" <%= product.isActive ? 'checked' : '' %>>
                    <label class="form-check-label" for="isActive">Aktif</label>
                </div>
                <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
                <a href="/admin/products" class="btn btn-secondary">Batal</a>
            </form>
        </main>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>
