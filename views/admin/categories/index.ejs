<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../../partials/header') %>
    <div class="admin-container">
        <%- include('../partials/sidebar', { activePage: 'categories' }) %>
        <main class="admin-main-content">
            <h1><%= title %></h1>

            <% if (success) { %>
                <div class="alert alert-success"><%= success %></div>
            <% } %>
            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <a href="/admin/categories/add" class="btn btn-primary mb-3">Tambah Kategori Baru</a>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nama</th>
                        <th>Slug</th>
                        <th>Deskripsi</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% categories.forEach(category => { %>
                        <tr>
                            <td><%= category.name %></td>
                            <td><%= category.slug %></td>
                            <td><%= category.description || '-' %></td>
                            <td>
                                <a href="/admin/categories/edit/<%= category._id %>" class="btn btn-warning btn-sm">Edit</a>
                                <form action="/admin/categories/delete/<%= category._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Anda yakin ingin menghapus kategori ini?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </main>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>
