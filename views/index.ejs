<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        .featured-products-section {
            margin-top: 40px;
        }

        .featured-products-section h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #2c3e50;
            font-size: 2rem;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .product-card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 10px rgba(0,0,0,.08);
            overflow: hidden;
            transition: .2s;
        }

        .product-card:hover {
            transform: translateY(-5px);
        }

        .product-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .product-card-body {
            padding: 15px;
            text-align: center;
        }

        .product-card-body h3 {
            margin-bottom: 10px;
        }

        .product-card-body h3 a {
            color: #2c3e50;
            text-decoration: none;
        }

        .price {
            color: #e67e22;
            font-weight: bold;
        }

        .wholesale {
            display: block;
            color: #27ae60;
            font-size: .9rem;
            margin-top: 5px;
        }

        .btn-add-to-cart {
            margin-top: 15px;
            background: #3498db;
            color: white;
            border: none;
            padding: 10px 16px;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-add-to-cart:hover {
            background: #2980b9;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            padding: 12px;
            border-radius: 5px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

<%- include('partials/header') %>

<main>

    <section class="hero-section"
        style="background:url('/img/hero-banner.jpg') center/cover;
        padding:100px 20px;
        text-align:center;
        color:white;
        border-radius:10px;
        margin-bottom:40px;">

        <h1>BELANJA LEBIH HEMAT, STOK MELIMPAH!</h1>

        <p style="margin-top:15px;font-size:18px">
            Diskon Hingga 50% Untuk Member Baru
        </p>

        <a href="/register" class="btn btn-primary" style="margin-top:20px;display:inline-block">
            Daftar Sekarang
        </a>

    </section>

    <% if (typeof error !== 'undefined' && error) { %>

        <div class="alert-danger">
            <%= error %>
        </div>

    <% } %>

    <section class="featured-products-section">

        <h2>Produk Unggulan</h2>

        <% if (products && products.length > 0) { %>

            <div class="product-grid">

                <% products.forEach(product => { %>

                    <div class="product-card">

                        <a href="/products/<%= product.slug %>">

                            <% if (product.images && product.images.length > 0) { %>

                                <img src="<%= product.images[0] %>" alt="<%= product.name %>">

                            <% } else { %>

                                <img src="/img/placeholder.png">

                            <% } %>

                        </a>

                        <div class="product-card-body">

                            <h3>
                                <a href="/products/<%= product.slug %>">
                                    <%= product.name %>
                                </a>
                            </h3>

                            <p class="price">

                                Rp
                                <%= Number(product.price || 0).toLocaleString('id-ID') %>

                                <% if (product.unit) { %>
                                    / <%= product.unit %>
                                <% } %>

                                <span class="wholesale">

                                    Grosir :

                                    Rp
                                    <%= Number(product.wholesalePrice || 0).toLocaleString('id-ID') %>

                                    <% if (product.minOrderQuantity) { %>
                                        (Min. <%= product.minOrderQuantity %>)
                                    <% } %>

                                </span>

                            </p>

                            <button
                                class="btn-add-to-cart"
                                data-product-id="<%= product._id %>"
                                data-product-name="<%= product.name %>"
                                data-product-price="<%= product.wholesalePrice %>"
                                data-product-unit="<%= product.unit %>"
                                data-product-moq="<%= product.minOrderQuantity %>">

                                Tambah ke Keranjang

                            </button>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } else { %>

            <p style="text-align:center">
                Belum ada produk unggulan.
            </p>

        <% } %>

    </section>

    <p style="text-align:center;margin-top:35px">
        Lihat semua produk
        <a href="/products">di sini</a>.
    </p>

</main>

<%- include('partials/footer') %>

<script src="/js/cart.js"></script>

</body>
</html>
