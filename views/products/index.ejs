<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .product-card {
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            text-align: center;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
            transition: .2s;
        }

        .product-card:hover {
            transform: translateY(-5px);
        }

        .product-card img {
            width:100%;
            height:200px;
            object-fit:cover;
        }

        .product-card-body{
            padding:15px;
        }

        .product-card-body h3{
            margin-top:0;
            font-size:1.2rem;
            margin-bottom:10px;
        }

        .product-card-body h3 a{
            text-decoration:none;
            color:#2c3e50;
        }

        .price{
            font-size:1.1rem;
            font-weight:bold;
            color:#e67e22;
        }

        .wholesale{
            display:block;
            color:#27ae60;
            font-size:.9rem;
            margin-top:5px;
        }

        .btn-add-to-cart{
            background:#3498db;
            color:#fff;
            border:none;
            padding:10px 15px;
            border-radius:5px;
            cursor:pointer;
            margin-top:10px;
        }

        .btn-add-to-cart:hover{
            background:#2980b9;
        }

        .main-content-flex{
            display:flex;
            gap:20px;
        }

        .sidebar-filter{
            width:220px;
            background:#fff;
            border-radius:8px;
            padding:20px;
            box-shadow:0 2px 10px rgba(0,0,0,.05);
        }

        .sidebar-filter ul{
            list-style:none;
            padding:0;
            margin:0;
        }

        .sidebar-filter li{
            margin-bottom:10px;
        }

        .sidebar-filter a{
            text-decoration:none;
            color:#555;
        }

        .sidebar-filter a.active{
            color:#3498db;
            font-weight:bold;
        }

        .products-list-area{
            flex:1;
        }

        .alert-danger{
            background:#f8d7da;
            color:#721c24;
            padding:10px;
            border-radius:5px;
            margin-bottom:20px;
        }
    </style>
</head>
<body>

<%- include('../partials/header') %>

<main class="main-content-flex">

    <aside class="sidebar-filter">
        <h3>Kategori</h3>

        <ul>

            <li>
                <a href="/products"
                   class="<%= !selectedCategory ? 'active' : '' %>">
                    Semua Produk
                </a>
            </li>

            <% if (categories && categories.length > 0) { %>

                <% categories.forEach(cat => { %>

                    <li>
                        <a href="/products?category=<%= cat.slug %>"
                           class="<%= selectedCategory === cat.slug ? 'active' : '' %>">
                            <%= cat.name %>
                        </a>
                    </li>

                <% }) %>

            <% } %>

        </ul>
    </aside>

    <div class="products-list-area">

        <h1><%= title %></h1>

        <% if (typeof error !== 'undefined' && error) { %>

            <div class="alert-danger">
                <%= error %>
            </div>

        <% } %>

        <% if (products && products.length > 0) { %>

            <div class="product-grid">

                <% products.forEach(product => { %>

                    <div class="product-card">

                        <a href="/products/<%= product.slug %>">

                            <% if (product.images && product.images.length > 0) { %>

                                <img src="<%= product.images[0] %>" alt="<%= product.name %>">

                            <% } else { %>

                                <img src="/img/placeholder.png" alt="No Image">

                            <% } %>

                        </a>

                        <div class="product-card-body">

                            <h3>
                                <a href="/products/<%= product.slug %>">
                                    <%= product.name %>
                                </a>
                            </h3>

                            <p class="price">

                                Rp <%= Number(product.price || 0).toLocaleString('id-ID') %>

                                <% if (product.unit) { %>
                                    / <%= product.unit %>
                                <% } %>

                                <span class="wholesale">

                                    Grosir :
                                    Rp <%= Number(product.wholesalePrice || 0).toLocaleString('id-ID') %>

                                    <% if (product.minOrderQuantity) { %>
                                        (Min. <%= product.minOrderQuantity %>)
                                    <% } %>

                                </span>

                            </p>

                            <button
                                class="btn-add-to-cart"
                                data-product-id="<%= product._id %>"
                                data-product-name="<%= product.name %>"
                                data-product-price="<%= product.wholesalePrice %>"
                                data-product-unit="<%= product.unit %>"
                                data-product-moq="<%= product.minOrderQuantity %>">

                                Tambah ke Keranjang

                            </button>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } else { %>

            <p>Tidak ada produk yang ditemukan.</p>

        <% } %>

    </div>

</main>

<%- include('../partials/footer') %>

<script src="/js/cart.js"></script>

</body>
</html>
